---
import SpaceAstronaut from './SpaceAstronaut.astro';
import SpaceMoon from './SpaceMoon.astro';
import FeatureIcon from './FeatureIcon.astro';

interface Props {
  data: any;
  lang: 'de' | 'en';
}

const { data, lang } = Astro.props;
const color = data.color;
const isDE = lang === 'de';

const t = {
  de: { inDev: 'In Entwicklung', productsTitle: 'Die Bausteine', flowTitle: 'Der Flow', exampleTitle: data.example.title },
  en: { inDev: 'In development', productsTitle: 'The Building Blocks', flowTitle: 'The Flow', exampleTitle: data.example.title },
}[lang];
---

<style>
  @keyframes heroFloat {
    0%, 100% { transform: translateY(0px) rotate(-3deg); }
    50%       { transform: translateY(-18px) rotate(3deg); }
  }
  @keyframes heroPulse {
    0%, 100% { opacity: 0.05; }
    50%       { opacity: 0.12; }
  }
  .hero-astronaut-float { animation: heroFloat 7s ease-in-out infinite; transform-origin: center; }
  .hero-glow-pulse { animation: heroPulse 4s ease-in-out infinite; }
</style>

<!-- ===== HERO ===== -->
<section class="relative overflow-hidden px-6 py-28 md:py-36">
  <div class="pointer-events-none absolute inset-0">
    <div class="hero-glow-pulse absolute top-0 left-1/2 -translate-x-1/2 h-[500px] w-[700px] rounded-full blur-3xl" style={`background: ${color}14;`}></div>
    <div class="hero-glow-pulse absolute top-32 left-1/4 h-[300px] w-[400px] rounded-full blur-3xl" style="background: #38bdf80a;"></div>
    <div class="hero-glow-pulse absolute top-32 right-1/4 h-[300px] w-[400px] rounded-full blur-3xl" style="background: #818cf80a;"></div>
  </div>

  <div class="hero-astronaut-float pointer-events-none absolute top-1/2 right-[5%] -translate-y-1/2 opacity-25 hidden lg:block" aria-hidden="true">
    <div style="position:absolute;top:40px;left:80px;">
      <SpaceMoon size={60} orbitRadius={120} orbitDuration={35} />
    </div>
    <SpaceAstronaut width={180} height={198} />
  </div>

  <div class="relative mx-auto max-w-5xl">
    <div class="flex flex-col items-center text-center gap-8">
      <div class="h-24 w-24 rounded-3xl flex items-center justify-center" style={`background: linear-gradient(to bottom right, ${color}33, #38bdf826, #818cf81a); border: 1px solid ${color}40;`}>
        <img src={data.logo} alt={`${data.name} Logo`} width="56" height="56" class="h-14 w-14"/>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-2">
        {data.badges.map((badge: any) => (
          badge.type === 'warning'
            ? <span class="rounded-full bg-amber-500/10 border border-amber-500/20 px-3 py-1 text-xs font-medium text-amber-400">{badge.text}</span>
            : <span class="rounded-full bg-white/5 border border-white/10 px-3 py-1 text-xs text-white/50">{badge.text}</span>
        ))}
      </div>

      <div>
        <h1 class="text-5xl font-bold tracking-tight text-white mb-4 md:text-6xl">{data.name}</h1>
        <p class="text-xl text-white/60 max-w-2xl leading-relaxed">&bdquo;{data.tagline}&ldquo;</p>
        <p class="mt-4 text-white/45 max-w-2xl leading-relaxed">{data.hero.description}</p>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-4">
        <a href={data.cta.githubUrl} target="_blank" rel="noopener noreferrer"
          class="bg-[#22c55e] text-black font-semibold px-6 py-3 rounded-lg hover:bg-[#4ade80] transition-colors duration-200 inline-flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          {data.cta.githubLabel}
        </a>
        <a href={data.cta.altUrl}
          class="border border-white/20 text-white px-6 py-3 rounded-lg hover:border-white/40 transition-colors duration-200 inline-flex items-center gap-2">
          {data.cta.altLabel}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ===== ARCHITECTURE FLOW ===== -->
<section class="px-6 py-20 border-t border-white/5">
  <div class="mx-auto max-w-4xl">
    <div class="text-center mb-12">
      <h2 class="text-2xl font-bold text-white mb-3">{data.flow.title}</h2>
      <p class="text-white/45 max-w-xl mx-auto">{data.flow.description}</p>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-center gap-3 md:gap-0">
      {data.flow.steps.map((step: any, i: number) => (
        <>
          <div class="flex-shrink-0 rounded-xl border bg-[#111118] px-5 py-4 text-center min-w-[140px]"
            style={`border-color: ${step.color || '#ffffff1a'};`}>
            <div class="text-sm font-semibold text-white">{step.label}</div>
            <div class="text-xs text-white/40 mt-1">{step.sub}</div>
          </div>
          {i < data.flow.steps.length - 1 && (
            <div class="text-white/20 rotate-90 md:rotate-0 my-1 md:mx-2">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          )}
        </>
      ))}
    </div>
  </div>
</section>

<!-- ===== BUILDING BLOCKS ===== -->
<section class="px-6 py-20 border-t border-white/5">
  <div class="mx-auto max-w-5xl">
    <div class="text-center mb-12">
      <h2 class="text-2xl font-bold text-white mb-3">{t.productsTitle}</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {data.products.map((product: any) => (
        <a href={product.url}
          class="group block rounded-xl border border-white/8 bg-[#111118] p-6 hover:border-opacity-40 transition-all duration-300"
          style={`--hover-color: ${product.color};`}>
          <div class="flex items-start gap-4">
            <div class="h-12 w-12 flex-shrink-0 rounded-xl flex items-center justify-center" style={`background: ${product.color}1a; border: 1px solid ${product.color}30;`}>
              <img src={product.logo} alt={product.name} width="28" height="28" class="h-7 w-7"/>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <h3 class="font-semibold text-white group-hover:text-white transition-colors">{product.name}</h3>
                {product.status === 'ga'
                  ? <span class="rounded-full bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 text-[10px] text-emerald-400">GA</span>
                  : <span class="rounded-full bg-amber-500/10 border border-amber-500/20 px-2 py-0.5 text-[10px] text-amber-400">Soon</span>
                }
              </div>
              <div class="text-xs font-medium mb-2" style={`color: ${product.color};`}>{product.role}</div>
              <p class="text-xs text-white/40 leading-relaxed">{product.description}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ===== CAPABILITIES ===== -->
<section class="px-6 py-20 border-t border-white/5">
  <div class="mx-auto max-w-5xl">
    <div class="text-center mb-12">
      <h2 class="text-2xl font-bold text-white mb-3">{data.capabilities.title}</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {data.capabilities.items.map((item: any) => (
        <div class="rounded-xl border bg-[#111118] p-6" style={`border-color: ${item.color}26;`}>
          <div class="mb-4 h-10 w-10 rounded-lg flex items-center justify-center" style={`background: ${item.color}1a;`}>
            <FeatureIcon icon={item.icon} color={item.color} />
          </div>
          <h3 class="text-base font-semibold text-white mb-2">{item.title}</h3>
          <p class="text-sm text-white/45 leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== EXAMPLE FLOW ===== -->
<section class="px-6 py-20 border-t border-white/5">
  <div class="mx-auto max-w-3xl">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-bold text-white mb-3">{t.exampleTitle}</h2>
    </div>

    <div class="space-y-3">
      {data.example.steps.map((step: string, i: number) => (
        <div class="flex items-start gap-4 rounded-lg border border-white/8 bg-[#111118] px-5 py-4">
          <span class="flex-shrink-0 h-7 w-7 rounded-full bg-[#22c55e]/15 border border-[#22c55e]/25 flex items-center justify-center text-xs font-bold text-[#22c55e]">{i + 1}</span>
          <p class="text-sm text-white/60 leading-relaxed pt-0.5">{step}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== CTA ===== -->
<section class="px-6 py-20 border-t border-white/5">
  <div class="mx-auto max-w-2xl text-center">
    <div class="inline-flex items-center gap-2 rounded-full bg-amber-500/8 border border-amber-500/15 px-4 py-1.5 text-xs text-amber-400 mb-6">
      <span class="h-1.5 w-1.5 rounded-full bg-amber-400 animate-pulse"></span>
      {t.inDev}
    </div>
    <h2 class="text-2xl font-bold text-white mb-3">{data.cta.title}</h2>
    <p class="text-white/45 mb-8 leading-relaxed">{data.cta.description}</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={data.cta.githubUrl} target="_blank" rel="noopener noreferrer"
        class="bg-[#22c55e] text-black font-semibold px-6 py-3 rounded-lg hover:bg-[#4ade80] transition-colors duration-200 inline-flex items-center gap-2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        {data.cta.githubLabel}
      </a>
      <a href={data.cta.altUrl} class="border border-white/20 text-white px-6 py-3 rounded-lg hover:border-white/40 transition-colors duration-200">
        {data.cta.altLabel}
      </a>
    </div>
    <a href={data.cta.backUrl} class="inline-block mt-6 text-sm text-white/30 hover:text-white/60 transition-colors">{data.cta.backLabel}</a>
  </div>
</section>
