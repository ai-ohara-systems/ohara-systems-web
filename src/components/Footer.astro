---
interface Props {
  lang?: string;
}

const { lang = 'de' } = Astro.props;

const isDE = lang === 'de';

const navLinks = isDE
  ? [
      { label: 'Produkte', href: '/products/model-prism' },
      { label: 'Blog', href: 'https://blog.ohara.systems', external: true },
      { label: 'Kurse', href: 'https://courses.ohara.systems/de' },
      { label: 'Best Practices', href: '/best-practices' },
      { label: 'Docs', href: 'https://docs.ohara.systems', external: true },
    ]
  : [
      { label: 'Products', href: '/en/products/model-prism' },
      { label: 'Blog', href: 'https://blog.ohara.systems', external: true },
      { label: 'Courses', href: 'https://courses.ohara.systems' },
      { label: 'Best Practices', href: '/en/best-practices' },
      { label: 'Docs', href: 'https://docs.ohara.systems', external: true },
    ];

const tagline = isDE
  ? 'KI-Infrastruktur die funktioniert.'
  : 'AI infrastructure that works.';
---

<footer class="border-t border-white/10 bg-[#111118]">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <!-- Main footer grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Left: Logo + tagline -->
      <div class="flex flex-col gap-4">
        <a href={isDE ? '/' : '/en'} class="flex items-center gap-3 group w-fit">
          <img
            src="/ohara-systems-logo.svg"
            height="28"
            width="28"
            alt="ohara.systems logo"
            class="h-7 w-7"
          />
          <span class="font-semibold text-white group-hover:text-[#38bdf8] transition-colors duration-200">
            ohara.systems
          </span>
        </a>
        <p class="text-sm text-white/50 leading-relaxed max-w-xs">
          {tagline}
        </p>
      </div>

      <!-- Center: Navigation -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xs font-semibold uppercase tracking-widest text-white/30">
          {isDE ? 'Navigation' : 'Navigation'}
        </h3>
        <ul class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-white/50 hover:text-white transition-colors duration-200"
                {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: GitHub + Copyright -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xs font-semibold uppercase tracking-widest text-white/30">
          {isDE ? 'Produkte' : 'Products'}
        </h3>
        <ul class="flex flex-col gap-3">
          <li>
            <a
              href="/products/model-prism"
              class="text-sm text-white/50 hover:text-white transition-colors duration-200"
            >
              Model Prism
            </a>
          </li>
          <li>
            <a
              href="https://github.com/ai-ohara-systems"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-white/50 hover:text-white transition-colors duration-200 flex items-center gap-2"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
              </svg>
              GitHub
            </a>
          </li>
          <li>
            <a
              href="https://docs.ohara.systems"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-white/50 hover:text-white transition-colors duration-200"
            >
              Docs
            </a>
          </li>
          <li>
            <a
              href="mailto:ai@ohara.systems"
              class="text-sm text-white/50 hover:text-white transition-colors duration-200 flex items-center gap-2"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              ai@ohara.systems
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom note -->
    <div class="mt-12 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/20">
        &copy; 2026 ohara.systems
      </p>
      <div class="flex items-center gap-4 text-xs text-white/20">
        <a href={isDE ? '/impressum' : '/en/impressum'} class="hover:text-white/40 transition-colors">
          {isDE ? 'Impressum' : 'Imprint'}
        </a>
        <a href={isDE ? '/datenschutz' : '/en/privacy'} class="hover:text-white/40 transition-colors">
          {isDE ? 'Datenschutz' : 'Privacy'}
        </a>
        <a href="/license" class="hover:text-white/40 transition-colors">
          License
        </a>
      </div>
    </div>
  </div>
</footer>
