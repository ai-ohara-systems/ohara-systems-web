---
interface Props {
  /** SVG display width */
  width?: number;
  /** SVG display height */
  height?: number;
}

const { width = 180, height = 198 } = Astro.props;
---

<svg viewBox="0 0 200 220" width={width} height={height} xmlns="http://www.w3.org/2000/svg" class="space-astronaut">
  <defs>
    <radialGradient id="astro-vGrad" cx="35%" cy="30%" r="65%">
      <stop offset="0%"   stop-color="#1a2a3a"/>
      <stop offset="100%" stop-color="#060810"/>
    </radialGradient>
    <linearGradient id="astro-osv" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"   stop-color="#38bdf8"/>
      <stop offset="50%"  stop-color="#818cf8"/>
      <stop offset="100%" stop-color="#e879f9"/>
    </linearGradient>
    <filter id="astro-sg">
      <feGaussianBlur stdDeviation="3" result="b"/>
      <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="astro-vg">
      <feGaussianBlur stdDeviation="3" result="b"/>
      <feMerge><feMergeNode in="b"/><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <clipPath id="astro-vc"><ellipse cx="96" cy="72" rx="26" ry="22"/></clipPath>
  </defs>

  <!-- Tether line -->
  <line x1="100" y1="215" x2="100" y2="200"
    stroke="white" stroke-width="0.8" stroke-dasharray="3 5" opacity="0.25"/>

  <!-- Backpack -->
  <rect x="110" y="103" width="18" height="26" rx="4" fill="#e8e8ee" opacity="0.9"/>
  <line x1="115" y1="108" x2="115" y2="123" stroke="#aaa" stroke-width="0.7" opacity="0.5"/>
  <line x1="120" y1="108" x2="120" y2="123" stroke="#aaa" stroke-width="0.7" opacity="0.5"/>

  <!-- Torso -->
  <rect x="72" y="98" width="54" height="60" rx="14" fill="#dde4ee" opacity="0.92"/>
  <!-- Chest panel -->
  <rect x="80" y="110" width="22" height="16" rx="3" fill="#0a1520" opacity="0.8"/>
  <circle cx="85"  cy="116" r="1.5" fill="#38bdf8" opacity="0.9"/>
  <circle cx="91"  cy="116" r="1.5" fill="#38bdf8" opacity="0.7"/>
  <circle cx="97"  cy="116" r="1.5" fill="#e879f9" opacity="0.8"/>
  <line x1="82" y1="122" x2="100" y2="122" stroke="#38bdf8" stroke-width="0.7" opacity="0.5"/>

  <!-- Left arm (animated reaching) -->
  <g class="astro-arm-left">
    <rect x="57" y="102" width="16" height="36" rx="8" fill="#ccd4e0" opacity="0.88"/>
    <circle cx="65" cy="96" r="8" fill="#b8c0cc" opacity="0.85"/>
  </g>

  <!-- Right arm (animated reaching) -->
  <g class="astro-arm-right">
    <rect x="125" y="102" width="16" height="36" rx="8" fill="#ccd4e0" opacity="0.88"/>
    <circle cx="133" cy="96" r="8" fill="#b8c0cc" opacity="0.85"/>
  </g>

  <!-- Neck ring -->
  <rect x="78" y="91" width="42" height="10" rx="5" fill="#c8d0dc" opacity="0.9"/>

  <!-- Helmet -->
  <circle cx="100" cy="62" r="36" fill="#e0e8f0" opacity="0.9" filter="url(#astro-sg)"/>

  <!-- Visor -->
  <ellipse cx="96" cy="72" rx="26" ry="22" fill="url(#astro-vGrad)" opacity="1"/>

  <!-- ohara logo reflection in visor -->
  <g clip-path="url(#astro-vc)" opacity="0.85" filter="url(#astro-vg)">
    <!-- Orbital ring -->
    <circle cx="96" cy="72" r="14" stroke="url(#astro-osv)" stroke-width="0.8" fill="none" opacity="0.55"/>
    <!-- Inner ring -->
    <circle cx="96" cy="72" r="7" stroke="url(#astro-osv)" stroke-width="0.5" fill="none" opacity="0.2"/>
    <!-- Spokes -->
    <g stroke="url(#astro-osv)" stroke-width="0.6" opacity="0.3" stroke-linecap="round">
      <line x1="96" y1="72" x2="96" y2="58"/>
      <line x1="96" y1="72" x2="110" y2="72"/>
      <line x1="96" y1="72" x2="96" y2="86"/>
      <line x1="96" y1="72" x2="82"  y2="72"/>
    </g>
    <!-- 4 orbital nodes -->
    <circle cx="96"  cy="58" r="1.8" fill="#38bdf8" opacity="0.9"/>
    <circle cx="110" cy="72" r="1.8" fill="#818cf8" opacity="0.9"/>
    <circle cx="96"  cy="86" r="1.8" fill="#e879f9" opacity="0.9"/>
    <circle cx="82"  cy="72" r="1.8" fill="#818cf8" opacity="0.8"/>
    <!-- Central hub -->
    <circle cx="96" cy="72" r="4" fill="#818cf8" opacity="0.12"/>
    <circle cx="96" cy="72" r="2.5" fill="#818cf8" opacity="0.85"/>
    <circle cx="96" cy="72" r="1.2" fill="white"   opacity="0.97"/>
  </g>

  <!-- Visor shine + helmet ring -->
  <ellipse cx="88" cy="62" rx="10" ry="6" fill="white" opacity="0.08" transform="rotate(-20 88 62)"/>
  <circle cx="100" cy="62" r="36" fill="none" stroke="#c8d0dc" stroke-width="1.5" opacity="0.6"/>
</svg>

<style>
  @keyframes astroFloat {
    0%, 100% { transform: translateY(0px) rotate(-3deg); }
    50%      { transform: translateY(-18px) rotate(3deg); }
  }
  @keyframes astroReachLeft {
    0%, 100% { transform: rotate(-20deg); }
    40%      { transform: rotate(-55deg); }
    70%      { transform: rotate(-30deg); }
  }
  @keyframes astroReachRight {
    0%, 100% { transform: rotate(15deg); }
    35%      { transform: rotate(45deg); }
    65%      { transform: rotate(20deg); }
  }
  .astro-arm-left  { animation: astroReachLeft  6s ease-in-out infinite; transform-origin: 65px 102px; }
  .astro-arm-right { animation: astroReachRight 5s ease-in-out infinite 0.5s; transform-origin: 133px 102px; }
</style>
