---
import SpaceAstronaut from './SpaceAstronaut.astro';
import SpaceMoon from './SpaceMoon.astro';
import FeatureIcon from './FeatureIcon.astro';

interface Props {
  data: any;
  version: string;
  lang: 'de' | 'en';
}

const { data, version, lang } = Astro.props;
---

<style>
  @keyframes heroFloat {
    0%, 100% { transform: translateY(0px) rotate(-3deg); }
    50%       { transform: translateY(-18px) rotate(3deg); }
  }
  @keyframes heroPulse {
    0%, 100% { opacity: 0.05; }
    50%       { opacity: 0.13; }
  }
  .hero-astronaut-float { animation: heroFloat 7s ease-in-out infinite; transform-origin: center; }
  .hero-glow-pulse { animation: heroPulse 4s ease-in-out infinite; }
  @keyframes twinkle {
    0%, 100% { opacity: 0.15; }
    50%       { opacity: 0.9; }
  }
  .star { animation: twinkle var(--dur,3s) ease-in-out infinite; animation-delay: var(--del,0s); }
  .feature-card:hover { border-color: color-mix(in srgb, var(--fc) 30%, transparent); }
</style>

<!-- ===== HERO ===== -->
<section class="relative overflow-hidden px-6 py-28 md:py-36">
  <!-- Pulsing background glow in brand color -->
  <div class="pointer-events-none absolute inset-0">
    <div class="hero-glow-pulse absolute top-0 left-1/2 -translate-x-1/2 h-[600px] w-[800px] rounded-full bg-[#38bdf8] blur-3xl"></div>
    <div class="absolute top-20 right-1/4 h-[200px] w-[300px] rounded-full bg-[#818cf8]/5 blur-3xl"></div>
  </div>

  <!-- Stars -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="star absolute rounded-full bg-white" style="--dur:2.1s;--del:0s; width:2px;height:2px;top:8%; left:6%"></div>
    <div class="star absolute rounded-full bg-white" style="--dur:3.4s;--del:0.8s; width:1px;height:1px;top:15%; left:20%"></div>
    <div class="star absolute rounded-full bg-white" style="--dur:2.8s;--del:0.3s; width:2px;height:2px;top:6%; left:50%"></div>
    <div class="star absolute rounded-full bg-white" style="--dur:4s;--del:1.2s; width:3px;height:3px;top:4%; left:74%"></div>
    <div class="star absolute rounded-full bg-white" style="--dur:2.5s;--del:0.5s; width:1px;height:1px;top:20%; left:88%"></div>
    <div class="star absolute rounded-full bg-white" style="--dur:3.1s;--del:1.8s; width:2px;height:2px;top:70%; left:4%"></div>
    <div class="star absolute rounded-full bg-white" style="--dur:2.9s;--del:0.4s; width:1px;height:1px;top:62%; left:14%"></div>
  </div>

  <!-- Floating astronaut + orbiting moon (right side) -->
  <div class="hero-astronaut-float pointer-events-none absolute top-1/2 right-[5%] -translate-y-1/2 opacity-25 hidden lg:block" aria-hidden="true">
    <div style="position:absolute;top:40px;left:80px;">
      <SpaceMoon size={60} orbitRadius={120} orbitDuration={35} />
    </div>
    <SpaceAstronaut width={180} height={198} />
  </div>

  <div class="relative mx-auto max-w-5xl">
    <div class="flex flex-col items-center text-center gap-8">
      <!-- Logo -->
      <div class="h-24 w-24 rounded-3xl bg-gradient-to-br from-[#38bdf8]/20 via-[#818cf8]/20 to-[#e879f9]/20 border border-[#38bdf8]/20 flex items-center justify-center">
        <img
          src={data.logo}
          alt={`${data.name} Logo`}
          width="56"
          height="56"
          class="h-14 w-14"
        />
      </div>

      <!-- Badge row -->
      <div class="flex flex-wrap items-center justify-center gap-2">
        {data.badges.map((badge: any) => (
          badge.type === 'brand'
            ? <span class="rounded-full bg-[#38bdf8]/10 border border-[#38bdf8]/20 px-3 py-1 text-xs font-medium text-[#38bdf8]">{badge.text}</span>
            : <span class="rounded-full bg-white/5 border border-white/10 px-3 py-1 text-xs text-white/50">{badge.text}</span>
        ))}
        <span class="rounded-full bg-[#38bdf8]/10 border border-[#38bdf8]/20 px-3 py-1 text-xs font-medium text-[#38bdf8]">
          {version}
        </span>
        <a
          href={data.enterpriseLink}
          class="rounded-full bg-violet-500/10 border border-violet-500/25 px-3 py-1 text-xs font-medium text-violet-400 hover:bg-violet-500/15 transition-colors duration-200"
        >
          Enterprise &#10022;
        </a>
      </div>

      <div>
        <h1 class="text-5xl font-bold tracking-tight text-white mb-4 md:text-6xl">
          {data.name}
        </h1>
        <p class="text-xl text-white/60 max-w-2xl leading-relaxed" set:html={data.hero.description} />
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-4">
        <a
          href={data.ctas.demo.url}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-[#38bdf8] text-black font-semibold px-6 py-3 rounded-lg hover:bg-[#7dd3fc] transition-colors duration-200 inline-flex items-center gap-2"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/>
          </svg>
          {data.ctas.demo.label}
        </a>
        <a
          href={data.ctas.github.url}
          target="_blank"
          rel="noopener noreferrer"
          class="border border-white/20 text-white px-6 py-3 rounded-lg hover:border-white/40 transition-colors duration-200 inline-flex items-center gap-2"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          {data.ctas.github.label}
        </a>
        <a
          href={data.ctas.docs.url}
          target="_blank"
          rel="noopener noreferrer"
          class="border border-white/20 text-white px-6 py-3 rounded-lg hover:border-white/40 transition-colors duration-200 inline-flex items-center gap-2"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>
          </svg>
          {data.ctas.docs.label}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ===== KEY FEATURES ===== -->
<section class="px-6 py-24 border-t border-white/5">
  <div class="mx-auto max-w-7xl">
    <div class="mb-16 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white md:text-4xl">
        {data.features.title}
      </h2>
      <p class="mt-4 text-white/50 max-w-xl mx-auto">
        {data.features.subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {data.features.items.map((feature: any) => (
        <div
          class="feature-card rounded-xl border border-white/10 bg-[#111118] p-6 transition-all duration-300"
          style={`--fc: ${feature.color}`}
        >
          <div class="mb-4 h-10 w-10 rounded-lg flex items-center justify-center" style={`background: color-mix(in srgb, ${feature.color} 10%, transparent)`}>
            <FeatureIcon icon={feature.icon} color={feature.color} />
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{feature.title}</h3>
          <p class="text-sm text-white/50 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== QUICK START ===== -->
<section class="px-6 py-24 border-t border-white/5">
  <div class="mx-auto max-w-4xl">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white md:text-4xl">
        {data.quickStart.title}
      </h2>
      <p class="mt-4 text-white/50">
        {data.quickStart.subtitle}
      </p>
    </div>

    <!-- Docker image reference -->
    <div class="mb-6 flex items-center justify-center gap-2">
      <code class="text-xs text-white/40 bg-white/5 border border-white/10 rounded px-3 py-1.5 font-mono">
        docker pull {data.image}:{data.imageTag}
      </code>
    </div>

    <div class="rounded-xl border border-white/10 bg-[#111118] overflow-hidden" id="quickstart-tabs">
      <!-- Tab bar -->
      <div class="flex border-b border-white/10 bg-[#0a0a0f]">
        {data.quickStart.tabs.map((tab: any, i: number) => (
          <button
            class={`qs-tab px-4 py-3 text-sm transition-colors cursor-pointer ${i === 0 ? 'text-[#38bdf8] border-b-2 border-[#38bdf8] font-medium' : 'text-white/40 hover:text-white/60'}`}
            data-tab={i}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <!-- Code panels -->
      {data.quickStart.tabs.map((tab: any, i: number) => (
        <div class={`qs-panel p-6 overflow-x-auto ${i !== 0 ? 'hidden' : ''}`} data-panel={i}>
          <pre class="text-sm leading-relaxed font-mono text-white/80"><code>{tab.code}</code></pre>
        </div>
      ))}
    </div>

    <script>
      document.querySelectorAll('.qs-tab').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = btn.dataset.tab;
          document.querySelectorAll('.qs-tab').forEach(t => {
            t.classList.remove('text-[#38bdf8]', 'border-b-2', 'border-[#38bdf8]', 'font-medium');
            t.classList.add('text-white/40');
          });
          btn.classList.add('text-[#38bdf8]', 'border-b-2', 'border-[#38bdf8]', 'font-medium');
          btn.classList.remove('text-white/40');
          document.querySelectorAll('.qs-panel').forEach(p => {
            p.classList.toggle('hidden', p.dataset.panel !== idx);
          });
        });
      });
    </script>

    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={data.quickStart.guideUrl}
        class="bg-[#38bdf8] text-black font-semibold px-6 py-3 rounded-lg hover:bg-[#7dd3fc] transition-colors duration-200 inline-flex items-center gap-2"
      >
        {data.quickStart.guideLabel}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a
        href={data.ctas.github.url}
        target="_blank"
        rel="noopener noreferrer"
        class="border border-white/20 text-white px-6 py-3 rounded-lg hover:border-white/40 transition-colors duration-200 inline-flex items-center gap-2"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        View on GitHub
      </a>
    </div>
  </div>
</section>

<!-- ===== PROVIDERS ===== -->
<section class="px-6 py-24 border-t border-white/5">
  <div class="mx-auto max-w-5xl text-center">
    <h2 class="text-2xl font-bold tracking-tight text-white mb-4">
      {data.providers.title}
    </h2>
    <p class="text-white/50 mb-12">
      {data.providers.subtitle}
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-4">
      {data.providers.list.map((provider: string) => (
        <div class="rounded-lg border border-white/10 bg-[#111118] p-4 flex items-center justify-center hover:border-white/20 transition-colors">
          <span class="text-sm text-white/60">{provider}</span>
        </div>
      ))}
    </div>
    <p class="mt-6 text-xs text-white/30">
      {data.providers.extraNote}
    </p>
  </div>
</section>

<!-- ===== BOTTOM CTA ===== -->
<section class="px-6 py-24 border-t border-white/5">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-bold tracking-tight text-white mb-4">
      {data.bottomCta.title}
    </h2>
    <p class="text-white/50 mb-8">
      {data.bottomCta.description}
    </p>
    <a
      href={data.bottomCta.url}
      target="_blank"
      rel="noopener noreferrer"
      class="bg-[#38bdf8] text-black font-semibold px-8 py-4 rounded-lg hover:bg-[#7dd3fc] transition-colors duration-200 inline-flex items-center gap-2 text-lg"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
      </svg>
      {data.bottomCta.label}
    </a>
  </div>
</section>
