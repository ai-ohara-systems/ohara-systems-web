---
import FeatureIcon from './FeatureIcon.astro';

interface Props {
  data: any;
  lang: 'de' | 'en';
}

const { data, lang } = Astro.props;
---

<!-- ===== HERO ===== -->
<section class="relative overflow-hidden px-6 py-28 md:py-36">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 h-[600px] w-[800px] rounded-full bg-[#818cf8]/8 blur-3xl"></div>
    <div class="absolute top-20 right-1/4 h-[300px] w-[400px] rounded-full bg-[#e879f9]/5 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-5xl">
    <div class="flex flex-col items-center text-center gap-8">

      <div class="flex flex-wrap items-center justify-center gap-2">
        {data.badges.map((badge: any) => (
          badge.type === 'brand'
            ? <span class="rounded-full bg-[#818cf8]/15 border border-[#818cf8]/30 px-3 py-1 text-xs font-semibold text-[#818cf8]">{badge.text}</span>
            : <span class="rounded-full bg-white/5 border border-white/10 px-3 py-1 text-xs text-white/50">{badge.text}</span>
        ))}
      </div>

      <div>
        <h1 class="text-5xl font-bold tracking-tight text-white mb-4 md:text-6xl">
          {data.name} <span class="text-[#818cf8]">{data.nameHighlight}</span>
        </h1>
        <p class="text-xl text-white/60 max-w-2xl leading-relaxed">
          {data.hero.description}
        </p>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-4">
        <a
          href={data.ctas.sales.url}
          class="bg-[#818cf8] text-white font-semibold px-7 py-3 rounded-lg hover:bg-[#a5b4fc] transition-colors duration-200 inline-flex items-center gap-2"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          {data.ctas.sales.label}
        </a>
        <a
          href={data.ctas.free.url}
          class="border border-white/20 text-white px-6 py-3 rounded-lg hover:border-white/40 transition-colors duration-200"
        >
          {data.ctas.free.label}
        </a>
        <a
          href={data.ctas.demo.url}
          target="_blank"
          rel="noopener noreferrer"
          class="border border-[#818cf8]/40 text-[#818cf8] px-6 py-3 rounded-lg hover:border-[#818cf8]/70 transition-colors duration-200 inline-flex items-center gap-2"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          {data.ctas.demo.label}
        </a>
      </div>

    </div>
  </div>
</section>

<!-- ===== FREE vs ENTERPRISE ===== -->
<section class="px-6 py-20 border-t border-white/5">
  <div class="mx-auto max-w-5xl">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-3">{data.comparison.title}</h2>
      <p class="text-white/50">{data.comparison.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Free -->
      <div class="rounded-2xl border border-white/10 bg-white/3 p-8">
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-[#22c55e]/15 border border-[#22c55e]/25">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </span>
          <div>
            <h3 class="text-lg font-semibold text-white">{data.comparison.free.name}</h3>
            <p class="text-xs text-[#22c55e]">{data.comparison.free.tagline}</p>
          </div>
        </div>
        <ul class="space-y-3 text-sm text-white/60">
          {data.comparison.free.included.map((item: string) => (
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#22c55e] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>{item}</li>
          ))}
          {data.comparison.free.excluded.map((item: string) => (
            <li class="flex items-center gap-2 opacity-35"><svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>{item}</li>
          ))}
        </ul>
      </div>

      <!-- Enterprise -->
      <div class="rounded-2xl border border-[#818cf8]/30 bg-[#818cf8]/5 p-8 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-40 h-40 rounded-full bg-[#818cf8]/10 blur-3xl pointer-events-none"></div>
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-[#818cf8]/20 border border-[#818cf8]/30">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </span>
          <div>
            <h3 class="text-lg font-semibold text-white">{data.comparison.enterprise.name}</h3>
            <p class="text-xs text-[#818cf8]">{data.comparison.enterprise.tagline}</p>
          </div>
        </div>
        <ul class="space-y-3 text-sm text-white/70">
          {data.comparison.enterprise.items.map((item: any) => (
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-[#818cf8] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
              {item.detail
                ? <span><strong class="text-white">{item.label}</strong> &mdash; {item.detail}</span>
                : item.label
              }
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>

<!-- ===== FEATURE DEEP-DIVE ===== -->
<section class="px-6 py-20 border-t border-white/5">
  <div class="mx-auto max-w-5xl">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-bold text-white mb-3">{data.deepDive.title}</h2>
      <p class="text-white/50 max-w-xl mx-auto">{data.deepDive.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {data.deepDive.items.map((item: any) => (
        <div class="rounded-xl border border-white/8 bg-white/3 p-6 flex flex-col gap-3">
          <FeatureIcon icon={item.icon} color={item.color} />
          <h3 class="text-base font-semibold text-white">{item.title}</h3>
          <p class="text-sm text-white/50 leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== LICENSING ===== -->
<section class="px-6 py-20 border-t border-white/5">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="text-3xl font-bold text-white mb-4">{data.licensing.title}</h2>
    <p class="text-white/50 leading-relaxed mb-8">
      {data.licensing.description}
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-left mb-10">
      {data.licensing.options.map((option: any) => (
        <div class="rounded-lg border border-white/8 bg-white/3 p-5">
          <p class="text-sm font-semibold text-white mb-1">{option.title}</p>
          <p class="text-xs text-white/50">{option.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== CTA ===== -->
<section class="px-6 py-20 border-t border-white/5">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-bold text-white mb-4">{data.bottomCta.title}</h2>
    <p class="text-white/50 mb-8 leading-relaxed">
      {data.bottomCta.description}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={data.bottomCta.salesUrl}
        class="bg-[#818cf8] text-white font-semibold px-8 py-3 rounded-lg hover:bg-[#a5b4fc] transition-colors duration-200 inline-flex items-center gap-2"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        {data.bottomCta.salesLabel}
      </a>
      <a
        href={data.bottomCta.docsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="border border-white/20 text-white px-6 py-3 rounded-lg hover:border-white/40 transition-colors duration-200"
      >
        {data.bottomCta.docsLabel}
      </a>
    </div>
  </div>
</section>
