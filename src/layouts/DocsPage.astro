---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  lang?: string;
  section?: string;
  prev?: { title: string; href: string };
  next?: { title: string; href: string };
}

const {
  title,
  description,
  lang = 'de',
  section,
  prev,
  next,
} = Astro.props;

const docsBase = lang === 'de' ? '/docs' : '/en/docs';

const sidebarSections = [
  {
    title: lang === 'de' ? 'Einstieg' : 'Getting Started',
    pages: [
      { title: lang === 'de' ? 'Einführung' : 'Introduction', href: `${docsBase}/model-prism/introduction` },
      { title: lang === 'de' ? 'Schnellstart' : 'Quick Start', href: `${docsBase}/model-prism/getting-started` },
      { title: lang === 'de' ? 'Architektur' : 'Architecture', href: `${docsBase}/model-prism/architecture` },
    ],
  },
  {
    title: lang === 'de' ? 'Konfiguration' : 'Configuration',
    pages: [
      { title: lang === 'de' ? 'Provider' : 'Providers', href: `${docsBase}/model-prism/providers` },
      { title: lang === 'de' ? 'Tenants & API Keys' : 'Tenants & API Keys', href: `${docsBase}/model-prism/tenants` },
      { title: 'RBAC', href: `${docsBase}/model-prism/rbac` },
    ],
  },
  {
    title: 'Routing',
    pages: [
      { title: 'Auto-Routing', href: `${docsBase}/model-prism/auto-routing` },
      { title: lang === 'de' ? 'Regelsets' : 'Rule Sets', href: `${docsBase}/model-prism/routing-rules` },
    ],
  },
  {
    title: lang === 'de' ? 'API Referenz' : 'API Reference',
    pages: [
      { title: 'OpenAI API', href: `${docsBase}/model-prism/api/openai` },
      { title: 'Admin API', href: `${docsBase}/model-prism/api/admin` },
      { title: 'Changelog', href: `${docsBase}/model-prism/changelog` },
    ],
  },
];
---

<Base title={`${title} — Model Prism Docs | ohara.systems`} description={description} lang={lang}>
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="hidden lg:flex w-64 shrink-0 flex-col border-r border-white/10 bg-[#111118] px-4 py-8 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto">
      <div class="mb-6">
        <a href={docsBase} class="flex items-center gap-2 text-sm text-white/60 hover:text-white transition-colors mb-4">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          {lang === 'de' ? 'Docs Übersicht' : 'Docs Overview'}
        </a>
        <div class="flex items-center gap-2">
          <img src="/model-prism-logo.svg" alt="" width="16" height="16" class="h-4 w-4" />
          <span class="text-xs font-semibold text-white/50 uppercase tracking-widest">Model Prism</span>
        </div>
      </div>

      <nav class="flex flex-col gap-6">
        {sidebarSections.map((sec) => (
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-widest text-white/30 mb-2">{sec.title}</h3>
            <ul class="flex flex-col gap-1">
              {sec.pages.map((page) => (
                <li>
                  <a
                    href={page.href}
                    class="block rounded-md px-3 py-1.5 text-sm text-white/50 hover:text-white hover:bg-white/5 transition-colors"
                  >
                    {page.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <!-- Main content -->
    <main class="flex-1 min-w-0 px-6 md:px-12 py-12">
      <div class="mx-auto max-w-3xl">
        {section && (
          <div class="text-xs font-medium text-[#38bdf8] uppercase tracking-widest mb-3">{section}</div>
        )}
        <h1 class="text-3xl font-bold tracking-tight text-white mb-6">{title}</h1>

        <div class="prose prose-invert prose-sm max-w-none
          prose-headings:text-white prose-headings:font-bold prose-headings:tracking-tight
          prose-p:text-white/70 prose-p:leading-relaxed
          prose-a:text-[#38bdf8] prose-a:no-underline hover:prose-a:underline
          prose-code:text-[#38bdf8] prose-code:bg-white/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
          prose-pre:bg-[#111118] prose-pre:border prose-pre:border-white/10 prose-pre:rounded-xl
          prose-strong:text-white
          prose-li:text-white/70
          prose-hr:border-white/10
          prose-table:text-white/70
          prose-th:text-white prose-th:border-white/10
          prose-td:border-white/10
        ">
          <slot />
        </div>

        <!-- Prev / Next navigation -->
        {(prev || next) && (
          <div class="mt-16 pt-8 border-t border-white/10 flex items-center justify-between gap-4">
            {prev ? (
              <a href={prev.href} class="flex items-center gap-2 text-sm text-white/50 hover:text-white transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
                {prev.title}
              </a>
            ) : <div />}
            {next && (
              <a href={next.href} class="flex items-center gap-2 text-sm text-white/50 hover:text-white transition-colors ml-auto">
                {next.title}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            )}
          </div>
        )}
      </div>
    </main>
  </div>
</Base>
