---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  lang?: string;
  courseTitle?: string;
  chapter?: number;
  totalChapters?: number;
  prev?: { title: string; href: string };
  next?: { title: string; href: string };
}

const {
  title,
  description,
  lang = 'de',
  courseTitle,
  chapter,
  totalChapters,
  prev,
  next,
} = Astro.props;

const coursesBase = lang === 'de' ? '/courses' : '/en/courses';
const backLabel = lang === 'de' ? '← Zur Kursübersicht' : '← Back to course';
---

<Base title={`${title} | ohara.systems`} description={description} lang={lang}>
  <article class="px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <!-- Breadcrumb -->
      <a href={coursesBase} class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white transition-colors mb-8">
        {backLabel}
      </a>

      {courseTitle && (
        <div class="mb-3 text-xs font-medium text-[#38bdf8] uppercase tracking-widest">
          {courseTitle}
        </div>
      )}

      {(chapter !== undefined && totalChapters !== undefined) && (
        <div class="mb-4 flex items-center gap-3">
          <span class="text-xs text-white/30">
            {lang === 'de' ? `Kapitel ${chapter} von ${totalChapters}` : `Chapter ${chapter} of ${totalChapters}`}
          </span>
          <div class="flex-1 max-w-32 h-1 rounded-full bg-white/10">
            <div
              class="h-1 rounded-full bg-[#38bdf8]"
              style={`width: ${Math.round((chapter / totalChapters) * 100)}%`}
            ></div>
          </div>
        </div>
      )}

      <h1 class="text-3xl font-bold tracking-tight text-white mb-4">{title}</h1>
      <p class="text-white/50 text-lg mb-10 pb-10 border-b border-white/10">{description}</p>

      <div class="prose prose-invert prose-sm max-w-none
        prose-headings:text-white prose-headings:font-bold
        prose-p:text-white/70 prose-p:leading-relaxed
        prose-a:text-[#38bdf8] prose-a:no-underline hover:prose-a:underline
        prose-code:text-[#38bdf8] prose-code:bg-white/5 prose-code:px-1 prose-code:rounded
        prose-pre:bg-[#111118] prose-pre:border prose-pre:border-white/10 prose-pre:rounded-xl
        prose-strong:text-white
        prose-li:text-white/70
        prose-hr:border-white/10
      ">
        <slot />
      </div>

      <!-- Chapter navigation -->
      <div class="mt-16 pt-8 border-t border-white/10 flex items-center justify-between gap-4">
        {prev ? (
          <a href={prev.href} class="flex items-center gap-2 text-sm text-white/50 hover:text-white transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            {prev.title}
          </a>
        ) : <div />}
        {next && (
          <a
            href={next.href}
            class="flex items-center gap-2 bg-[#38bdf8] text-black font-semibold text-sm px-5 py-2.5 rounded-lg hover:bg-[#7dd3fc] transition-colors ml-auto"
          >
            {next.title}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        )}
      </div>
    </div>
  </article>
</Base>
