---
import Base from '../../../layouts/Base.astro';
import ModelPrismPage from '../../../components/ModelPrismPage.astro';
import { loadProductData } from '../../../lib/products';
import { getModelPrismVersion } from '../../../lib/versions';

const data = loadProductData('model-prism', 'en');
const version = await getModelPrismVersion();
---

<Base title={data.meta.title} description={data.meta.description} lang="en">
  <ModelPrismPage data={data} version={version} lang="en" />
</Base>
