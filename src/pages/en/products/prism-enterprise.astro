---
import Base from '../../../layouts/Base.astro';
import PrismEnterprisePage from '../../../components/PrismEnterprisePage.astro';
import { loadProductData } from '../../../lib/products';

const data = loadProductData('prism-enterprise', 'en');
---

<Base
  title={data.meta.title}
  description={data.meta.description}
  lang="en"
  canonicalPath="/en/products/prism-enterprise"
  alternatePath="/products/prism-enterprise"
>
  <PrismEnterprisePage data={data} lang="en" />
</Base>
