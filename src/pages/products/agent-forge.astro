---
import Base from '../../layouts/Base.astro';
import SpaceAstronaut from '../../components/SpaceAstronaut.astro';
import SpaceMoon from '../../components/SpaceMoon.astro';
---

<Base
  title="Agent Forge — Framework für AI-Agents | ohara.systems"
  description="Agent Forge ist ein Framework zum Aufbau, Anpassung und Deployment von AI-Agents — von der Idee zum produktionsreifen System."
  lang="de"
  canonicalPath="/products/agent-forge"
  alternatePath="/en/products/agent-forge"
>

  <style>
    @keyframes heroFloat {
      0%, 100% { transform: translateY(0px) rotate(-3deg); }
      50%       { transform: translateY(-18px) rotate(3deg); }
    }
    @keyframes heroPulse {
      0%, 100% { opacity: 0.05; }
      50%       { opacity: 0.12; }
    }
    .hero-astronaut-float { animation: heroFloat 7s ease-in-out infinite; transform-origin: center; }
    .hero-glow-pulse { animation: heroPulse 4s ease-in-out infinite; }
  </style>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden px-6 py-28 md:py-36">
    <!-- Pulsing background glow in brand color -->
    <div class="pointer-events-none absolute inset-0">
      <div class="hero-glow-pulse absolute top-0 left-1/2 -translate-x-1/2 h-[500px] w-[700px] rounded-full blur-3xl" style="background: rgba(232, 121, 249, 0.08);"></div>
    </div>

    <!-- Floating astronaut + orbiting moon -->
    <div class="hero-astronaut-float pointer-events-none absolute top-1/2 right-[5%] -translate-y-1/2 opacity-25 hidden lg:block" aria-hidden="true">
      <div style="position:absolute;top:40px;left:80px;">
        <SpaceMoon size={60} orbitRadius={120} orbitDuration={35} />
      </div>
      <SpaceAstronaut width={180} height={198} />
    </div>

    <div class="relative mx-auto max-w-5xl">
      <div class="flex flex-col items-center text-center gap-8">
        <!-- Logo -->
        <div class="h-24 w-24 rounded-3xl bg-gradient-to-br from-[#f97316]/15 via-[#e879f9]/15 to-[#818cf8]/10 border border-[#e879f9]/20 flex items-center justify-center">
          <img src="/agent-forge-logo.svg" alt="Agent Forge Logo" width="56" height="56" class="h-14 w-14"/>
        </div>

        <!-- Badge row -->
        <div class="flex flex-wrap items-center justify-center gap-2">
          <span class="rounded-full bg-amber-500/10 border border-amber-500/20 px-3 py-1 text-xs font-medium text-amber-400">
            Coming soon
          </span>
          <span class="rounded-full bg-white/5 border border-white/10 px-3 py-1 text-xs text-white/50">
            ohara AI Factory
          </span>
        </div>

        <div>
          <h1 class="text-5xl font-bold tracking-tight text-white mb-4 md:text-6xl">
            Agent Forge
          </h1>
          <p class="text-xl text-white/60 max-w-2xl leading-relaxed">
            „Forge intelligent systems."
          </p>
          <p class="mt-4 text-white/45 max-w-2xl leading-relaxed">
            Ein Framework zum Aufbau, Anpassung und Deployment von AI-Agents —
            definiere Verhalten, Tools und Orchestrierungslogik und verwandle Ideen in produktionsreife Systeme.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row items-center gap-4">
          <a
            href="https://github.com/ai-ohara-systems"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl bg-white/8 border border-white/15 px-6 py-3 text-sm font-medium text-white hover:bg-white/12 transition-all duration-200"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub folgen
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CONCEPT ===== -->
  <section class="px-6 py-20 border-t border-white/5">
    <div class="mx-auto max-w-4xl">
      <div class="text-center mb-16">
        <h2 class="text-2xl font-bold text-white mb-4">Das Konzept</h2>
        <p class="text-white/50 max-w-2xl mx-auto leading-relaxed">
          Bestehende Frameworks sind entweder zu abstrakt oder zu starr. Agent Forge gibt dir die volle
          Kontrolle über Verhalten, Tools und Orchestrierung — ohne Komplexität zu verstecken.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1 -->
        <div class="rounded-2xl border border-[#e879f9]/15 bg-[#111118] p-6">
          <div class="h-10 w-10 rounded-xl bg-[#e879f9]/10 border border-[#e879f9]/20 flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#e879f9" stroke-width="1.5"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </div>
          <h3 class="font-semibold text-white mb-2">Agent-Verhalten definieren</h3>
          <p class="text-sm text-white/50 leading-relaxed">
            Beschreibe, wie dein Agent entscheidet, welche Tools er nutzt und wie er auf Ergebnisse reagiert — deklarativ und versionierbar.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="rounded-2xl border border-[#e879f9]/15 bg-[#111118] p-6">
          <div class="h-10 w-10 rounded-xl bg-[#e879f9]/10 border border-[#e879f9]/20 flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#e879f9" stroke-width="1.5"><path d="M8 6H5a2 2 0 00-2 2v9a2 2 0 002 2h3m8-13h3a2 2 0 012 2v9a2 2 0 01-2 2h-3m-8 0V6m8 13V6M8 6h8"/></svg>
          </div>
          <h3 class="font-semibold text-white mb-2">Orchestrierung &amp; Pipelines</h3>
          <p class="text-sm text-white/50 leading-relaxed">
            Verbinde Agents zu mehrstufigen Pipelines — mit klarer Übergabe von Kontext, Fehlern und Ergebnissen zwischen den Schritten.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="rounded-2xl border border-[#e879f9]/15 bg-[#111118] p-6">
          <div class="h-10 w-10 rounded-xl bg-[#e879f9]/10 border border-[#e879f9]/20 flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#e879f9" stroke-width="1.5"><path d="M5 12.55a11 11 0 0114.08 0M1.42 9a16 16 0 0121.16 0M8.53 16.11a6 6 0 016.95 0M12 20h.01"/></svg>
          </div>
          <h3 class="font-semibold text-white mb-2">Self-hosted &amp; Privat</h3>
          <p class="text-sm text-white/50 leading-relaxed">
            Kein Vendor Lock-in. Betreibe Agent Forge in deiner eigenen Infrastruktur — vollständig unter deiner Kontrolle.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="px-6 py-20 border-t border-white/5">
    <div class="mx-auto max-w-2xl text-center">
      <div class="inline-flex items-center gap-2 rounded-full bg-amber-500/8 border border-amber-500/15 px-4 py-1.5 text-xs text-amber-400 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-amber-400 animate-pulse"></span>
        In Entwicklung
      </div>
      <h2 class="text-2xl font-bold text-white mb-4">Bleib auf dem Laufenden</h2>
      <p class="text-white/50 mb-8">
        Agent Forge ist Teil der ohara AI Factory. Folge uns auf GitHub für Early Access und Updates.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://github.com/ai-ohara-systems"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-white/8 border border-white/15 px-6 py-3 text-sm font-medium text-white hover:bg-white/12 transition-all duration-200"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub folgen
        </a>
        <a href="/" class="text-sm text-white/40 hover:text-white/70 transition-colors">
          Zurück zur Übersicht
        </a>
      </div>
    </div>
  </section>

</Base>
