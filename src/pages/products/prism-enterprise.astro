---
import Base from '../../layouts/Base.astro';
import PrismEnterprisePage from '../../components/PrismEnterprisePage.astro';
import { loadProductData } from '../../lib/products';

const data = loadProductData('prism-enterprise', 'de');
---

<Base
  title={data.meta.title}
  description={data.meta.description}
  lang="de"
  canonicalPath="/products/prism-enterprise"
  alternatePath="/en/products/prism-enterprise"
>
  <PrismEnterprisePage data={data} lang="de" />
</Base>
