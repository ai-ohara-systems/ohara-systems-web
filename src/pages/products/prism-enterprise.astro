---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Model Prism Enterprise — Erweitertes KI-Gateway für Teams | ohara.systems"
  description="Model Prism Enterprise schaltet Multi-Tenant-Verwaltung, eigene Routing-Kategorien, LDAP/SSO, Budget-Kontrolle, Advanced Routing und Priority-Support frei. Self-hosted, air-gapped ready."
  lang="de"
  canonicalPath="/products/prism-enterprise"
  alternatePath="/en/products/prism-enterprise"
>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden px-6 py-28 md:py-36">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 h-[600px] w-[800px] rounded-full bg-[#818cf8]/8 blur-3xl"></div>
      <div class="absolute top-20 right-1/4 h-[300px] w-[400px] rounded-full bg-[#e879f9]/5 blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-5xl">
      <div class="flex flex-col items-center text-center gap-8">

        <div class="flex flex-wrap items-center justify-center gap-2">
          <span class="rounded-full bg-[#818cf8]/15 border border-[#818cf8]/30 px-3 py-1 text-xs font-semibold text-[#818cf8]">
            Enterprise
          </span>
          <span class="rounded-full bg-white/5 border border-white/10 px-3 py-1 text-xs text-white/50">
            Self-hosted
          </span>
          <span class="rounded-full bg-white/5 border border-white/10 px-3 py-1 text-xs text-white/50">
            Air-gapped ready
          </span>
          <span class="rounded-full bg-white/5 border border-white/10 px-3 py-1 text-xs text-white/50">
            Offline-Lizenz
          </span>
        </div>

        <div>
          <h1 class="text-5xl font-bold tracking-tight text-white mb-4 md:text-6xl">
            Model Prism <span class="text-[#818cf8]">Enterprise</span>
          </h1>
          <p class="text-xl text-white/60 max-w-2xl leading-relaxed">
            Alles aus der Free-Edition — plus Multi-Tenant-Verwaltung, eigene Routing-Kategorien,
            LDAP/SSO, Budget-Kontrolle und dedizierter Unterstützung. Gebaut für Teams, die KI im großen Maßstab betreiben.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row items-center gap-4">
          <a
            href="mailto:ai@ohara.systems?subject=Model%20Prism%20Enterprise%20Lizenz"
            class="bg-[#818cf8] text-white font-semibold px-7 py-3 rounded-lg hover:bg-[#a5b4fc] transition-colors duration-200 inline-flex items-center gap-2"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Vertrieb kontaktieren
          </a>
          <a
            href="/products/model-prism"
            class="border border-white/20 text-white px-6 py-3 rounded-lg hover:border-white/40 transition-colors duration-200"
          >
            Free Edition ansehen
          </a>
          <a
            href="https://demo-prism.ohara.systems"
            target="_blank"
            rel="noopener noreferrer"
            class="border border-[#818cf8]/40 text-[#818cf8] px-6 py-3 rounded-lg hover:border-[#818cf8]/70 transition-colors duration-200 inline-flex items-center gap-2"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Live Demo
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== FREE vs ENTERPRISE ===== -->
  <section class="px-6 py-20 border-t border-white/5">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-3">Free vs. Enterprise</h2>
        <p class="text-white/50">Alles, was du zum Vergleich brauchst — kein Verkaufsgespräch nötig.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- Free -->
        <div class="rounded-2xl border border-white/10 bg-white/3 p-8">
          <div class="flex items-center gap-3 mb-6">
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-[#22c55e]/15 border border-[#22c55e]/25">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </span>
            <div>
              <h3 class="text-lg font-semibold text-white">Free</h3>
              <p class="text-xs text-[#22c55e]">Source Available — immer kostenlos</p>
            </div>
          </div>
          <ul class="space-y-3 text-sm text-white/60">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#22c55e] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>Einzelner Mandant (eigener API-Key)</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#22c55e] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>Intelligentes Modell-Routing</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#22c55e] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>50+ Modell-Provider</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#22c55e] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>Kosten-Tracking &amp; Analytics</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#22c55e] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>Request-Logging</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#22c55e] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>Schreibgeschützte Tenant-Ansicht</li>
            <li class="flex items-center gap-2 opacity-35"><svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>Multi-Tenant-Verwaltung</li>
            <li class="flex items-center gap-2 opacity-35"><svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>Eigene Routing-Kategorien</li>
            <li class="flex items-center gap-2 opacity-35"><svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>LDAP / SSO</li>
            <li class="flex items-center gap-2 opacity-35"><svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>Budget-Limits pro Tenant</li>
            <li class="flex items-center gap-2 opacity-35"><svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>Kategorie-Benchmarks</li>
            <li class="flex items-center gap-2 opacity-35"><svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>Priority-Support</li>
            <li class="flex items-center gap-2 opacity-35"><svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>Custom Theming</li>
            <li class="flex items-center gap-2 opacity-35"><svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>Backlog-Priorisierung</li>
          </ul>
        </div>

        <!-- Enterprise -->
        <div class="rounded-2xl border border-[#818cf8]/30 bg-[#818cf8]/5 p-8 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-40 h-40 rounded-full bg-[#818cf8]/10 blur-3xl pointer-events-none"></div>
          <div class="flex items-center gap-3 mb-6">
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-[#818cf8]/20 border border-[#818cf8]/30">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </span>
            <div>
              <h3 class="text-lg font-semibold text-white">Enterprise</h3>
              <p class="text-xs text-[#818cf8]">Preis auf Anfrage</p>
            </div>
          </div>
          <ul class="space-y-3 text-sm text-white/70">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#818cf8] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>Alles aus Free</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#818cf8] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg><span><strong class="text-white">Multi-Tenant-Verwaltung</strong> — unbegrenzt Tenants anlegen &amp; verwalten</span></li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#818cf8] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg><span><strong class="text-white">Eigene Routing-Kategorien</strong> — eigene Modellauswahl-Logik definieren</span></li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#818cf8] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg><span><strong class="text-white">LDAP / SSO</strong> — Unternehmensverzeichnis anbinden</span></li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#818cf8] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg><span><strong class="text-white">Budget-Limits</strong> — Ausgabenobergrenzen pro Tenant mit Alerts</span></li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#818cf8] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg><span><strong class="text-white">Kategorie-Benchmarks</strong> — Routing-Genauigkeit evaluieren</span></li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#818cf8] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg><span><strong class="text-white">Priority-Support</strong> — dedizierte E-Mail-Adresse, 24h Response-SLA</span></li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#818cf8] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg><span><strong class="text-white">Custom Theming</strong> — White-Label mit eigenem Branding</span></li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#818cf8] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg><span><strong class="text-white">Backlog-Priorisierung</strong> — die Produkt-Roadmap direkt beeinflussen</span></li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#818cf8] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>Offline-Lizenzschlüssel — funktioniert vollständig air-gapped</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== FEATURE DEEP-DIVE ===== -->
  <section class="px-6 py-20 border-t border-white/5">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-bold text-white mb-3">Gebaut für Enterprise KI-Betrieb</h2>
        <p class="text-white/50 max-w-xl mx-auto">Model Prism Enterprise gibt deinem Plattform-Team volle Kontrolle darüber, wie KI in der gesamten Organisation eingesetzt wird.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

        <div class="rounded-xl border border-white/8 bg-white/3 p-6 flex flex-col gap-3">
          <div class="w-10 h-10 rounded-lg bg-[#38bdf8]/15 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#38bdf8" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3 class="text-base font-semibold text-white">Multi-Tenant-Verwaltung</h3>
          <p class="text-sm text-white/50 leading-relaxed">Unbegrenzt Tenants anlegen und verwalten — jeder mit isolierten API-Keys, Modellzugang und Nutzungskontingenten. Ideal für Teams, Abteilungen oder Kunden.</p>
        </div>

        <div class="rounded-xl border border-white/8 bg-white/3 p-6 flex flex-col gap-3">
          <div class="w-10 h-10 rounded-lg bg-[#818cf8]/15 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
          </div>
          <h3 class="text-base font-semibold text-white">Eigene Routing-Kategorien</h3>
          <p class="text-sm text-white/50 leading-relaxed">Eigene Aufgaben-Kategorien definieren und den richtigen Modellen zuordnen. Preset-Profile hinzufügen, Routing-Genauigkeit benchmarken und für Kosten vs. Qualität optimieren.</p>
        </div>

        <div class="rounded-xl border border-white/8 bg-white/3 p-6 flex flex-col gap-3">
          <div class="w-10 h-10 rounded-lg bg-[#22c55e]/15 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="text-base font-semibold text-white">LDAP / SSO-Integration</h3>
          <p class="text-sm text-white/50 leading-relaxed">Active Directory oder beliebigen LDAP-Server anbinden. Nutzer automatisch synchronisieren, gruppenbasierte Zugriffsrichtlinien durchsetzen und manuelle Nutzerverwaltung eliminieren.</p>
        </div>

        <div class="rounded-xl border border-white/8 bg-white/3 p-6 flex flex-col gap-3">
          <div class="w-10 h-10 rounded-lg bg-[#f59e0b]/15 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="text-base font-semibold text-white">Budget-Limits &amp; Alerts</h3>
          <p class="text-sm text-white/50 leading-relaxed">Harte oder weiche Ausgabenobergrenzen pro Tenant setzen. Alerts erhalten, wenn Budgets sich dem Limit nähern, und Tenants automatisch drosseln oder sperren.</p>
        </div>

        <div class="rounded-xl border border-white/8 bg-white/3 p-6 flex flex-col gap-3">
          <div class="w-10 h-10 rounded-lg bg-[#e879f9]/15 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#e879f9" stroke-width="1.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3 class="text-base font-semibold text-white">Priority-Support</h3>
          <p class="text-sm text-white/50 leading-relaxed">Dedizierte E-Mail-Adresse mit 24h Response-SLA. Direkter Zugang zum Engineering-Team für Eskalationen, Migrationen und Integrationshilfe.</p>
        </div>

        <div class="rounded-xl border border-white/8 bg-white/3 p-6 flex flex-col gap-3">
          <div class="w-10 h-10 rounded-lg bg-[#38bdf8]/15 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#38bdf8" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <h3 class="text-base font-semibold text-white">Backlog-Priorisierung</h3>
          <p class="text-sm text-white/50 leading-relaxed">Enterprise-Kunden können die Model Prism-Roadmap direkt beeinflussen. Features voten, Custom-Integrationen anfragen und sie schneller umgesetzt bekommen.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== LICENSING ===== -->
  <section class="px-6 py-20 border-t border-white/5">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Flexible Lizenzierung</h2>
      <p class="text-white/50 leading-relaxed mb-8">
        Enterprise-Lizenzen werden als Offline-Keys ausgeliefert — keine Telemetrie, keine Internetverbindung erforderlich.
        Vollständig air-gapped deploybar. Die Lizenzvalidierung erfolgt lokal per asymmetrischer Kryptographie.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-left mb-10">
        <div class="rounded-lg border border-white/8 bg-white/3 p-5">
          <p class="text-sm font-semibold text-white mb-1">Offline-Key</p>
          <p class="text-xs text-white/50">Lokal signieren und verifizieren. Funktioniert ohne Netzwerkzugang. Kein Callback nach Hause.</p>
        </div>
        <div class="rounded-lg border border-white/8 bg-white/3 p-5">
          <p class="text-sm font-semibold text-white mb-1">Lizenzserver</p>
          <p class="text-xs text-white/50">Mit <span class="text-[#38bdf8]">license.ohara.systems</span> verbinden für verwaltete Key-Distribution und -Erneuerung.</p>
        </div>
        <div class="rounded-lg border border-white/8 bg-white/3 p-5">
          <p class="text-sm font-semibold text-white mb-1">Individueller Vertrag</p>
          <p class="text-xs text-white/50">Volumenlizenzen, unbefristete Lizenzen und individuelle Konditionen für größere Teams verfügbar.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="px-6 py-20 border-t border-white/5">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Bereit zu skalieren?</h2>
      <p class="text-white/50 mb-8 leading-relaxed">
        Erzähl uns von deinem Setup — wir schicken dir innerhalb eines Werktages ein Enterprise-Angebot.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="mailto:ai@ohara.systems?subject=Model%20Prism%20Enterprise%20Lizenz"
          class="bg-[#818cf8] text-white font-semibold px-8 py-3 rounded-lg hover:bg-[#a5b4fc] transition-colors duration-200 inline-flex items-center gap-2"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Vertrieb kontaktieren — ai@ohara.systems
        </a>
        <a
          href="https://docs.ohara.systems/prism"
          target="_blank"
          rel="noopener noreferrer"
          class="border border-white/20 text-white px-6 py-3 rounded-lg hover:border-white/40 transition-colors duration-200"
        >
          Dokumentation lesen
        </a>
      </div>
    </div>
  </section>

</Base>
