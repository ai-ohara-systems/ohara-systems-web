---
import Base from '../../layouts/Base.astro';
import ProductsOverviewPage from '../../components/ProductsOverviewPage.astro';
import { loadProductData } from '../../lib/products';
import { getModelPrismVersion } from '../../lib/versions';

const prism = loadProductData('model-prism', 'de');
const enterprise = loadProductData('prism-enterprise', 'de');
const atlas = loadProductData('agent-atlas', 'de');
const forge = loadProductData('agent-forge', 'de');
const flux = loadProductData('prompt-flux', 'de');
const version = await getModelPrismVersion();
---

<Base
  title="Produkte — ohara AI Factory | ohara.systems"
  description="Die ohara AI Factory: Model Prism, Agent Atlas, Agent Forge und Prompt Flux — AI-Infrastruktur für Teams (ELv2)."
  lang="de"
  canonicalPath="/products"
  alternatePath="/en/products"
>
  <ProductsOverviewPage lang="de" version={version} prism={prism} enterprise={enterprise} atlas={atlas} forge={forge} flux={flux} />
</Base>
